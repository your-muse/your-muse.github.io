<img src="article-2.png" alt="Manchild article" class="article-image">

  <!-- SHARE / LIKE / DISLIKE -->
<div class="article-actions">

  <button class="icon-btn" onclick="sharePost()">
    <i class="fa-solid fa-share-nodes"></i>
  </button>

  <div class="like-wrapper">
    <button class="icon-btn like-btn" onclick="handleLike(this)">
      <i class="fa-regular fa-thumbs-up"></i>
    </button>
    <span id="like-count">0</span>
  </div>

  <button class="icon-btn dislike-btn" onclick="toggleDislike(this)">
    <i class="fa-regular fa-thumbs-down"></i>
  </button>

</div>

